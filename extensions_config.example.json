{
  "mcpInterceptors": [
    "my_package.mcp.auth:build_auth_interceptor"
  ],
  "mcpServers": {
    "filesystem": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/allowed/files"
      ],
      "env": {},
      "description": "Provides filesystem access within allowed directories"
    },
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access"
    },
    "scite": {
      "enabled": false,
      "type": "sse",
      "url": "http://host.docker.internal:8095/scite/sse",
      "description": "Scite API for literature citation contexts and exact manuscript claim verification"
    },
    "consensus": {
      "enabled": false,
      "type": "sse",
      "url": "http://host.docker.internal:8095/consensus/sse",
      "description": "Consensus API for academic search and claim grounding"
    },
    "arxiv": {
      "enabled": false,
      "type": "stdio",
      "command": "uv",
      "args": [
        "x",
        "mcp-server-arxiv"
      ],
      "description": "arXiv MCP server for direct paper lookup and metadata fetching"
    }
  },
  "skills": {}
}