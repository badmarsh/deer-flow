{
  "mcpInterceptors": [
    "my_package.mcp.auth:build_auth_interceptor"
  ],
  "mcpServers": {
    "filesystem": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/allowed/files"
      ],
      "env": {},
      "description": "Provides filesystem access within allowed directories"
    },
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access"
    },
    "consensus": {
      "enabled": true,
      "type": "sse",
      "url": "http://host.docker.internal:8095/consensus/sse",
      "headers": {
        "Authorization": "Bearer $CONSENSUS_API_KEY"
      },
      "description": "Consensus MCP server for research and knowledge synthesis"
    },
    "onyx": {
      "enabled": true,
      "type": "sse",
      "url": "http://host.docker.internal:8096/onyx/sse",
      "headers": {
        "Authorization": "Bearer $ONYX_API_KEY"
      },
      "description": "Onyx MCP server"
    }
  },
  "skills": {}
}
